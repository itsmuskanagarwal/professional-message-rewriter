# Anthropic API (Claude Haiku)
# Required. Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Upstash Redis (rate limiting)
# Required. Create a database at https://console.upstash.com — use REST API credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Sentry (error tracking)
# Get your DSN at https://sentry.io
SENTRY_DSN=

# Optional: PostHog (product analytics)
# Get your key and host at https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
