{
  "name": "@professional-message-writer/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agents/*": "./src/agents/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./skills/*": "./src/skills/*.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "openai": "^6.37.0"
  }
}
